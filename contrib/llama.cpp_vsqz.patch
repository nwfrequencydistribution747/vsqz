     FILE *fp = fopen(fname, "rb");
     if (!fp) return false;
@@ -18,6 +198,15 @@ bool gguf_open(struct gguf_context *ctx, const char *fname) {
     if (fread(&magic, sizeof(magic), 1, fp) != 1) { fclose(fp); return false; }
     fclose(fp);

+    // ── .vsqz detection ──────────────────────────────────────────
+    if (is_vsqz(magic)) {
+        vsqz_context vsqz;
+        if (!vsqz_open(vsqz, fname)) return false;
+        // Route through vsqz→GGUF bridge (transparent conversion)
+        bool ok = gguf_open_from_vsqz(ctx, vsqz);
+        vsqz_close(vsqz);
+        return ok;
+    }
+
     if (magic != GGUF_MAGIC) return false;

     // (existing GGUF loading continues below)
